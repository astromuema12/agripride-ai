# Vercel Environment Configuration
# Set these in Vercel Dashboard → Project Settings → Environment Variables

# --- Supabase (REQUIRED) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI / AI (REQUIRED for real AI) ---
OPENAI_API_KEY=

# --- Flutterwave (REQUIRED for payments) ---
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET=

# --- M-Pesa (set in Vercel env, NEVER in local files) ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_ENV=production

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://agripride-ai.vercel.app
NEXT_PUBLIC_APP_NAME=AgriPride AI
NEXT_PUBLIC_CONTACT_EMAIL=musauedwin2004@gmail.com

# --- Feature Flags ---
ENABLE_AI_DIAGNOSTICS=true
ENABLE_AI_CHAT=true
ENABLE_MPESA=true
ENABLE_FLUTTERWAVE=true
ENABLE_DEMO_MODE=true

# --- Monitoring ---
NEXT_PUBLIC_SENTRY_DSN=
