# ============================================
# AgriPride AI — Required Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
# All marked REQUIRED must be set for production.

# --- Supabase (REQUIRED for production) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI / AI (REQUIRED for real AI) ---
OPENAI_API_KEY=

# --- NextAuth / Auth (REQUIRED) ---
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# --- App Config ---
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME=AgriPride AI
NEXT_PUBLIC_CONTACT_EMAIL=musauedwin2004@gmail.com

# --- Rate Limiting (optional, defaults) ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/webp

# --- M-Pesa (future) ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_ENV=sandbox

# --- Flutterwave (REQUIRED for payments) ---
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET=

# --- Sentry / Monitoring (optional) ---
NEXT_PUBLIC_SENTRY_DSN=

# --- Feature Flags ---
ENABLE_AI_DIAGNOSTICS=true
ENABLE_AI_CHAT=true
ENABLE_MPESA=false
ENABLE_FLUTTERWAVE=false
ENABLE_DEMO_MODE=true
